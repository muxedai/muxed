{
  "name": "toold",
  "version": "0.1.0",
  "description": "MCP server daemon and aggregator CLI – aggregate all your Model Context Protocol servers behind a single background daemon with lazy start, auto-reconnect, and idle shutdown",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/client/index.mjs",
      "types": "./dist/client/index.d.mts"
    },
    "./client": {
      "import": "./dist/client/index.mjs",
      "types": "./dist/client/index.d.mts"
    }
  },
  "bin": {
    "toold": "./bin/cli.mjs"
  },
  "files": [
    "dist",
    "bin",
    "toold.generated.d.ts"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "mcp-proxy",
    "mcp-aggregator",
    "mcp-daemon",
    "mcp-cli",
    "mcp-tools",
    "ai-coding",
    "claude-code",
    "cursor",
    "windsurf",
    "ai-agent",
    "tool-server",
    "daemon",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/skoob13/toold.git",
    "directory": "packages/toold"
  },
  "homepage": "https://github.com/skoob13/toold#readme",
  "bugs": {
    "url": "https://github.com/skoob13/toold/issues"
  },
  "author": "Georgiy Tarasov",
  "license": "MIT",
  "scripts": {
    "build": "obuild",
    "dev": "node src/cli.ts",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "test": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "commander": "^14.0.0",
    "json-schema-to-typescript": "^15.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@modelcontextprotocol/server-everything": "^2026.1.26",
    "@types/node": "^22.0.0",
    "obuild": "^0.4.22",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  }
}
