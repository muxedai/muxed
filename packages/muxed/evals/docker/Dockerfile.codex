FROM node:22-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates && \
    rm -rf /var/lib/apt/lists/*

RUN npm install -g @openai/codex muxed

RUN useradd -m -s /bin/bash agent
RUN mkdir -p /home/agent/.codex && chown agent:agent /home/agent/.codex
USER agent

WORKDIR /workspace

ENTRYPOINT ["codex"]
