---
import "../styles/landing.css";

const title = "mcpd — The optimization layer for MCP";
const description =
  "One daemon to manage them all. Fewer tokens, faster tools, better agents.";

const asciiLogo = `                        _
  _ __ ___   ___ _ __   __| |
 | '_ \` _ \\ / __| '_ \\ / _\` |
 | | | | | | (__| |_) | (_| |
 |_| |_| |_|\\___| .__/ \\__,_|
                 |_|`;

const codeDiscovery = `<span class="ln"> 1</span> <span class="comment"># find the tool you need — not all 200</span>
<span class="ln"> 2</span> <span class="dollar">$</span> mcpd grep <span class="str">"read"</span>
<span class="ln"> 3</span> <span class="output">  filesystem/read_file      Read file contents</span>
<span class="ln"> 4</span> <span class="output">  postgres/query            Read data via SQL</span>
<span class="ln"> 5</span>
<span class="ln"> 6</span> <span class="comment"># inspect its schema</span>
<span class="ln"> 7</span> <span class="dollar">$</span> mcpd info filesystem/read_file
<span class="ln"> 8</span> <span class="output">  path (string, required)   File path to read</span>
<span class="ln"> 9</span>
<span class="ln">10</span> <span class="comment"># call it — only the result enters the LLM</span>
<span class="ln">11</span> <span class="dollar">$</span> mcpd call filesystem/read_file \\
<span class="ln">12</span>     <span class="str">'{"path": "/tmp/config.json"}'</span>`;

const codeChaining = `<span class="ln">1</span> <span class="comment"># query → filter → write. model never sees the raw 10k rows.</span>
<span class="ln">2</span> <span class="dollar">$</span> mcpd call postgres/query \\
<span class="ln">3</span>     <span class="str">'{"sql":"SELECT * FROM users"}'</span> <span class="flag">--json</span> \\
<span class="ln">4</span>   | jq <span class="str">'[.[] | select(.active)]'</span> \\
<span class="ln">5</span>   | mcpd call filesystem/write_file \\
<span class="ln">6</span>     <span class="str">'{"path":"/tmp/active.json"}'</span> <span class="flag">-</span>`;

const codeNodeApi = `<span class="ln"> 1</span> <span class="kw">import</span> { createClient } <span class="kw">from</span> <span class="str">'mcpd'</span>;
<span class="ln"> 2</span>
<span class="ln"> 3</span> <span class="kw">const</span> client = <span class="kw">await</span> createClient();
<span class="ln"> 4</span>
<span class="ln"> 5</span> <span class="comment">// query churned customers from PostHog</span>
<span class="ln"> 6</span> <span class="kw">const</span> churn = <span class="kw">await</span> client.call(<span class="str">'posthog/query-run'</span>, {
<span class="ln"> 7</span>   query: { kind: <span class="str">'HogQLQuery'</span>, query: <span class="str">'SELECT email FROM persons'</span> }
<span class="ln"> 8</span> });
<span class="ln"> 9</span>
<span class="ln">10</span> <span class="comment">// pull support history in parallel</span>
<span class="ln">11</span> <span class="kw">const</span> history = <span class="kw">await</span> Promise.all(
<span class="ln">12</span>   customers.map(c =&gt;
<span class="ln">13</span>     client.call(<span class="str">'intercom/search-conversations'</span>, {
<span class="ln">14</span>       query: c.email, limit: 5
<span class="ln">15</span>     })
<span class="ln">16</span>   )
<span class="ln">17</span> );
<span class="ln">18</span>
<span class="ln">19</span> <span class="comment">// output the results</span>
<span class="ln">20</span> console.log(history);`;

const codeBefore = `<span class="output">⛁ ⛁ ⛁ ⛁ ⛁ ⛁ </span><span class="kw">⛁ </span><span class="flag">⛁ </span><span class="str">⛁ ⛁</span>
<span class="str">⛁ ⛁ ⛁ ⛁ ⛁ ⛁ ⛁ ⛁ ⛁ ⛁</span>`;

const codeAfter = `<span class="kw">⛁ </span><span class="flag">⛁ </span><span class="str">⛁ ⛁ ⛁ ⛁ ⛁ ⛁ ⛁ ⛁</span>
<span class="str">⛁ ⛁ ⛁ ⛁ </span><span class="comment">⛶ ⛶ ⛶ ⛶ ⛶ ⛶</span>`;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href="https://mcpd.dev" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://mcpd.dev" />
  </head>
  <body class="font-mono bg-page text-fg text-sm leading-[1.6] antialiased">
    <!-- Navigation -->
    <div class="max-w-[960px] mx-auto px-6">
      <nav class="flex items-center justify-between py-4 border-b border-edge">
        <div class="font-bold text-[15px] -tracking-wide text-fg flex items-center gap-2">
          <span class="text-brand">$</span> mcpd
        </div>
        <div class="flex items-center gap-4 md:gap-6 text-[13px]">
          <a href="/getting-started/installation/" class="text-fg-muted hover:text-fg transition-colors !no-underline">Docs</a>
          <a href="https://github.com/skoob13/mcpd" class="text-fg-muted hover:text-fg transition-colors !no-underline">GitHub</a>
          <a href="https://www.npmjs.com/package/mcpd" class="text-fg-muted hover:text-fg transition-colors !no-underline">npm</a>
        </div>
      </nav>
    </div>

    <!-- Hero -->
    <div class="max-w-[960px] mx-auto px-6">
      <section class="py-8 md:py-16 section-divided">
        <div class="text-center pt-8 relative hero-glow">
          <pre class="ascii-logo text-fg text-[11px] leading-tight tracking-wider whitespace-pre mb-8 opacity-90">{asciiLogo}</pre>

          <div class="text-[13px] font-normal tracking-[0.2em] uppercase text-fg-muted mb-8">
            Fewer tokens. Faster tools. Better agents.
          </div>

          <p class="text-[15px] text-fg-muted max-w-[600px] mx-auto mb-8 leading-relaxed">
            Your coding agent gets dumber with every MCP you add. mcpd offloads
            them to a daemon and discovers tools lazily — via shell or Node.js
            API.
          </p>

          <div
            class="shimmer-border inline-flex items-center gap-3 bg-raised border border-edge rounded-lg px-5 py-3 text-sm mb-6 cursor-pointer hover:border-edge-light hover:bg-hover transition relative overflow-hidden"
            id="install-box"
          >
            <span class="text-green select-none">$</span>
            <span class="text-fg">npx mcpd init</span>
            <span class="text-fg-faint text-[11px] ml-3 transition-colors" id="copy-hint">click to copy</span>
          </div>

          <div class="flex flex-col md:flex-row justify-center items-center gap-4 mt-6">
            <a href="/getting-started/installation/" class="btn btn-primary">Get Started</a>
            <a href="https://github.com/skoob13/mcpd" class="btn">GitHub</a>
          </div>
        </div>
      </section>
    </div>

    <!-- The Problem -->
    <div class="max-w-[960px] mx-auto px-6">
      <section class="py-8 md:py-16 section-divided">
        <div class="text-center mb-6 md:mb-8">
          <h2 class="text-[13px] font-normal tracking-[0.2em] uppercase text-fg-faint">The problem with MCP at scale</h2>
        </div>

        <p class="text-[13px] text-fg-muted leading-relaxed text-center max-w-[640px] mx-auto mb-8">
          Every MCP server dumps its full schema into the prompt. One server is
          fine. Three is a problem. Ten breaks things.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8 stats-stagger">
          <div class="bg-surface border border-edge rounded-lg p-6 text-center hover:border-edge-light transition animate-in">
            <div class="text-[28px] font-bold text-brand mb-1 stat-glow">98.7%</div>
            <div class="text-[11px] text-fg-faint uppercase tracking-wide mb-2">token overhead</div>
            <p class="text-xs text-fg-muted">
              Anthropic found that intermediate tool results waste almost all
              tokens flowing through the model.
            </p>
          </div>
          <div class="bg-surface border border-edge rounded-lg p-6 text-center hover:border-edge-light transition animate-in">
            <div class="text-[28px] font-bold text-brand mb-1 stat-glow">20-30%</div>
            <div class="text-[11px] text-fg-faint uppercase tracking-wide mb-2">context consumed</div>
            <p class="text-xs text-fg-muted">
              A standard 3-4 server setup fills a quarter of the context window
              before the agent even starts.
            </p>
          </div>
          <div class="bg-surface border border-edge rounded-lg p-6 text-center hover:border-edge-light transition animate-in">
            <div class="text-[28px] font-bold text-brand mb-1 stat-glow">3-4</div>
            <div class="text-[11px] text-fg-faint uppercase tracking-wide mb-2">server limit</div>
            <p class="text-xs text-fg-muted">
              Tool selection accuracy collapses after just a handful of
              connected MCP servers.
            </p>
          </div>
        </div>

        <p class="text-sm text-fg font-medium text-center">
          More tools in context = worse results. Every token spent on schemas is
          a token not spent on your task.
        </p>
      </section>
    </div>

    <!-- Features Grid -->
    <div class="max-w-[960px] mx-auto px-6">
      <section class="py-8 md:py-16 section-divided">
        <div class="text-center mb-6 md:mb-8">
          <h2 class="text-[13px] font-normal tracking-[0.2em] uppercase text-fg-faint">How mcpd fixes this</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 features-stagger">
          <div class="bg-surface border border-edge border-l-2 border-l-brand rounded-lg p-6 hover:border-edge-light hover:border-l-brand hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(129,140,248,0.08)] transition-all animate-in">
            <div class="text-sm mb-3 text-brand leading-none">-98%</div>
            <h3 class="text-[13px] font-semibold mb-2 text-fg">Fewer tokens</h3>
            <p class="text-xs text-fg-muted leading-relaxed">
              Tools live in the daemon, not the prompt. Agents discover what
              they need on demand with <code class="text-brand bg-raised px-1 py-px rounded text-[11px]">mcpd grep</code>.
            </p>
          </div>
          <div class="bg-surface border border-edge border-l-2 border-l-brand rounded-lg p-6 hover:border-edge-light hover:border-l-brand hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(129,140,248,0.08)] transition-all animate-in">
            <div class="text-lg mb-3 text-brand leading-none">&#x26a1;</div>
            <h3 class="text-[13px] font-semibold mb-2 text-fg">Always warm</h3>
            <p class="text-xs text-fg-muted leading-relaxed">
              Background daemon keeps every server connected. No cold starts, no
              handshake delays. Tools respond in milliseconds.
            </p>
          </div>
          <div class="bg-surface border border-edge border-l-2 border-l-brand rounded-lg p-6 hover:border-edge-light hover:border-l-brand hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(129,140,248,0.08)] transition-all animate-in">
            <div class="text-lg mb-3 text-brand leading-none">&#x25ce;</div>
            <h3 class="text-[13px] font-semibold mb-2 text-fg">Better accuracy</h3>
            <p class="text-xs text-fg-muted leading-relaxed">
              Fewer schemas in context means the model picks the right tool more
              often. Clean context, better reasoning.
            </p>
          </div>
          <div class="bg-surface border border-edge border-l-2 border-l-brand rounded-lg p-6 hover:border-edge-light hover:border-l-brand hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(129,140,248,0.08)] transition-all animate-in">
            <div class="text-lg mb-3 text-brand leading-none">|&gt;</div>
            <h3 class="text-[13px] font-semibold mb-2 text-fg">Chain &amp; script</h3>
            <p class="text-xs text-fg-muted leading-relaxed">
              Pipe results through bash, jq, or Node.js. Intermediate data stays
              outside the model entirely.
            </p>
          </div>
          <div class="bg-surface border border-edge border-l-2 border-l-brand rounded-lg p-6 hover:border-edge-light hover:border-l-brand hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(129,140,248,0.08)] transition-all animate-in">
            <div class="text-lg mb-3 text-brand leading-none">&#x2605;</div>
            <h3 class="text-[13px] font-semibold mb-2 text-fg">Context engineering</h3>
            <p class="text-xs text-fg-muted leading-relaxed">
              Reclaim context for skills, prompts, and default tools &mdash; the
              things models execute deterministically.
            </p>
          </div>
          <div class="bg-surface border border-edge border-l-2 border-l-brand rounded-lg p-6 hover:border-edge-light hover:border-l-brand hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(129,140,248,0.08)] transition-all animate-in">
            <div class="text-lg mb-3 text-brand leading-none">&#123;&#125;</div>
            <h3 class="text-[13px] font-semibold mb-2 text-fg">Zero config</h3>
            <p class="text-xs text-fg-muted leading-relaxed">
              Reads your existing agent configs. Or run <code class="text-brand bg-raised px-1 py-px rounded text-[11px]">mcpd init</code> to
              auto-discover servers.
            </p>
          </div>
        </div>
      </section>
    </div>

    <!-- Code Example: Discovery -->
    <div class="max-w-[960px] mx-auto px-6">
      <section class="py-8 md:py-16 section-divided">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
          <div>
            <h2 class="text-xl font-semibold mb-3 text-fg">Discover, don't preload</h2>
            <p class="text-[13px] text-fg-muted leading-relaxed">
              Instead of loading every schema into the prompt, agents search for
              the tool they need, inspect it, and call it. The model's context
              stays clean &mdash; only the final result goes in.
            </p>
          </div>

          <div class="code-block bg-surface border border-edge rounded-lg overflow-hidden">
            <div class="code-header flex items-center gap-2 px-4 py-3 border-b border-edge">
              <div class="w-2.5 h-2.5 rounded-full bg-[#ff5f57]"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-[#febc2e]"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-[#28c840]"></div>
              <span class="text-[11px] text-fg-faint ml-2">terminal</span>
            </div>
            <pre class="p-4 text-xs leading-relaxed overflow-x-auto" set:html={codeDiscovery} />
          </div>
        </div>
      </section>
    </div>

    <!-- Code Example: Scripting -->
    <div class="max-w-[960px] mx-auto px-6">
      <section class="py-8 md:py-16 section-divided">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
          <div>
            <h2 class="text-xl font-semibold mb-3 text-fg">Write scripts, not tool calls</h2>
            <p class="text-[13px] text-fg-muted leading-relaxed">
              Agents can chain MCP calls through bash pipes or write Node.js
              scripts using the <code class="text-brand bg-raised px-1 py-px rounded text-[11px]">mcpd</code> client library. Either way, intermediate
              data never re-enters the model.
            </p>
            <p class="text-[13px] text-fg-muted leading-relaxed mt-3">
              Same insight behind Anthropic's code execution and Cloudflare's
              Code Mode &mdash; as a CLI and npm package.
            </p>
          </div>

          <div class="code-block bg-surface border border-edge rounded-lg overflow-hidden">
            <div class="code-header flex items-center gap-2 px-4 py-3 border-b border-edge">
              <div class="w-2.5 h-2.5 rounded-full bg-[#ff5f57]"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-[#febc2e]"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-[#28c840]"></div>
              <span class="text-[11px] text-fg-faint ml-2">bash &mdash; pipe through jq</span>
            </div>
            <pre class="p-4 text-xs leading-relaxed overflow-x-auto" set:html={codeChaining} />
          </div>
        </div>

        <!-- Node.js example -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start mt-8">
          <div>
            <h2 class="text-xl font-semibold mb-3 text-fg">Node.js API</h2>
            <p class="text-[13px] text-fg-muted leading-relaxed">
              mcpd is also an npm package. Agents write Node.js scripts with
              typed results, <code class="text-brand bg-raised px-1 py-px rounded text-[11px]">Promise.all</code> for parallel calls across servers,
              and the full npm ecosystem.
            </p>
          </div>

          <div class="code-block bg-surface border border-edge rounded-lg overflow-hidden">
            <div class="code-header flex items-center gap-2 px-4 py-3 border-b border-edge">
              <div class="w-2.5 h-2.5 rounded-full bg-[#ff5f57]"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-[#febc2e]"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-[#28c840]"></div>
              <span class="text-[11px] text-fg-faint ml-2">churn-analysis.mjs</span>
            </div>
            <pre class="p-4 text-xs leading-relaxed overflow-x-auto" set:html={codeNodeApi} />
          </div>
        </div>
      </section>
    </div>

    <!-- Context Engineering -->
    <div class="max-w-[960px] mx-auto px-6">
      <section class="py-8 md:py-16 section-divided">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
          <div>
            <h2 class="text-xl font-semibold mb-3 text-fg">When tools leave, context wins</h2>
            <p class="text-[13px] text-fg-muted leading-relaxed">
              Skills, prompts, and default tools are deterministic &mdash;
              models always follow them. MCP tools compete for attention, and
              accuracy drops as you add more.
            </p>
            <p class="text-[13px] text-fg-muted leading-relaxed mt-3">
              Offloading tools to mcpd is context engineering at the
              infrastructure level. Your instructions get followed instead of
              being buried under thousands of tokens of schemas.
            </p>
          </div>

          <div class="code-block bg-surface border border-edge rounded-lg overflow-hidden">
            <div class="code-header flex items-center gap-2 px-4 py-3 border-b border-edge">
              <div class="w-2.5 h-2.5 rounded-full bg-[#ff5f57]"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-[#febc2e]"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-[#28c840]"></div>
              <span class="text-[11px] text-fg-faint ml-2">context window allocation</span>
            </div>
            <div class="flex flex-col gap-3 p-4">
              <div class="text-[11px] text-fg-faint uppercase tracking-wide font-mono">before mcpd:</div>
              <div class="flex flex-col md:flex-row gap-3 md:gap-6 items-start md:items-center">
                <pre class="context-grid font-mono text-[13px] leading-[1.6] text-fg p-0 m-0" set:html={codeBefore} />
                <div class="context-legend flex flex-col gap-1 text-[11px] font-mono text-fg-muted">
                  <div><span class="output">⛁</span> mcp tools 30%</div>
                  <div><span class="kw">⛁</span> skills 6%</div>
                  <div><span class="flag">⛁</span> prompts 6%</div>
                  <div><span class="str">⛁</span> task 58%</div>
                </div>
              </div>
              <div class="text-[11px] text-fg-faint uppercase tracking-wide font-mono mt-3 pt-3 border-t border-edge">after mcpd:</div>
              <div class="flex flex-col md:flex-row gap-3 md:gap-6 items-start md:items-center">
                <pre class="context-grid font-mono text-[13px] leading-[1.6] text-fg p-0 m-0" set:html={codeAfter} />
                <div class="context-legend flex flex-col gap-1 text-[11px] font-mono text-fg-muted">
                  <div><span class="kw">⛁</span> skills 6%</div>
                  <div><span class="flag">⛁</span> prompts 6%</div>
                  <div><span class="str">⛁</span> task 58%</div>
                  <div><span class="comment">⛶</span> free 30%</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>

    <!-- Get Started CTA -->
    <div class="max-w-[960px] mx-auto px-6">
      <section class="py-8 md:py-16 cta-glow">
        <div class="text-center max-w-[640px] mx-auto">
          <h2 class="text-xl font-semibold mb-3 text-fg">Get started in seconds</h2>
          <p class="text-[13px] text-fg-muted leading-relaxed mb-8">
            Auto-discover your MCP servers, start the daemon, and run your first
            tool call.
          </p>

          <div class="flex flex-col gap-4 text-left">
            <div class="flex items-baseline gap-4 bg-surface border border-edge rounded-lg px-5 py-4 hover:border-edge-light transition">
              <span class="text-brand font-bold text-sm shrink-0 w-[1.5ch]">1</span>
              <div>
                <code class="text-brand bg-raised px-1.5 py-px rounded text-[13px]">npx mcpd init</code>
                <span class="text-fg-faint text-xs ml-3">generates config from your existing setup</span>
              </div>
            </div>
            <div class="flex items-baseline gap-4 bg-surface border border-edge rounded-lg px-5 py-4 hover:border-edge-light transition">
              <span class="text-brand font-bold text-sm shrink-0 w-[1.5ch]">2</span>
              <div>
                <code class="text-brand bg-raised px-1.5 py-px rounded text-[13px]">mcpd tools</code>
                <span class="text-fg-faint text-xs ml-3">lists every tool across all servers</span>
              </div>
            </div>
            <div class="flex items-baseline gap-4 bg-surface border border-edge rounded-lg px-5 py-4 hover:border-edge-light transition">
              <span class="text-brand font-bold text-sm shrink-0 w-[1.5ch]">3</span>
              <div>
                <code class="text-brand bg-raised px-1.5 py-px rounded text-[13px]">mcpd call server/tool '{"{}"}'</code>
                <span class="text-fg-faint text-xs ml-3">invoke any tool from the command line</span>
              </div>
            </div>
          </div>

          <div class="flex flex-col md:flex-row justify-center items-center gap-4 mt-8">
            <a href="/getting-started/installation/" class="btn btn-primary">Read the Docs</a>
            <a href="https://github.com/skoob13/mcpd" class="btn">View on GitHub</a>
          </div>
        </div>
      </section>
    </div>

    <!-- Footer -->
    <div class="max-w-[960px] mx-auto px-6">
      <footer class="py-12 text-center text-xs text-fg-faint">
        <div class="flex justify-center gap-6 mb-4">
          <a href="/getting-started/installation/" class="text-fg-muted text-xs hover:text-fg">Docs</a>
          <a href="https://github.com/skoob13/mcpd" class="text-fg-muted text-xs hover:text-fg">GitHub</a>
          <a href="https://www.npmjs.com/package/mcpd" class="text-fg-muted text-xs hover:text-fg">npm</a>
          <a href="https://modelcontextprotocol.io" class="text-fg-muted text-xs hover:text-fg">MCP Spec</a>
        </div>
        <div class="text-fg-faint mb-3">
