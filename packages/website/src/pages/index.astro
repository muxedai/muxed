---
import "../styles/landing.css";

const title = "mcpd — The optimization layer for MCP";
const description =
  "One daemon to manage them all. Fewer tokens, faster tools, better agents.";

const asciiLogo = `                        _
  _ __ ___   ___ _ __   __| |
 | '_ \` _ \\ / __| '_ \\ / _\` |
 | | | | | | (__| |_) | (_| |
 |_| |_| |_|\\___| .__/ \\__,_|
                 |_|`;

const codeDiscovery = `<span class="ln"> 1</span> <span class="comment"># find the tool you need — not all 200</span>
<span class="ln"> 2</span> <span class="dollar">$</span> mcpd grep <span class="str">"read"</span>
<span class="ln"> 3</span> <span class="output">  filesystem/read_file      Read file contents</span>
<span class="ln"> 4</span> <span class="output">  postgres/query            Read data via SQL</span>
<span class="ln"> 5</span>
<span class="ln"> 6</span> <span class="comment"># inspect its schema</span>
<span class="ln"> 7</span> <span class="dollar">$</span> mcpd info filesystem/read_file
<span class="ln"> 8</span> <span class="output">  path (string, required)   File path to read</span>
<span class="ln"> 9</span>
<span class="ln">10</span> <span class="comment"># call it — only the result enters the LLM</span>
<span class="ln">11</span> <span class="dollar">$</span> mcpd call filesystem/read_file \\
<span class="ln">12</span>     <span class="str">'{"path": "/tmp/config.json"}'</span>`;

const codeChaining = `<span class="ln">1</span> <span class="comment"># query → filter → write. model never sees the raw 10k rows.</span>
<span class="ln">2</span> <span class="dollar">$</span> mcpd call postgres/query \\
<span class="ln">3</span>     <span class="str">'{"sql":"SELECT * FROM users"}'</span> <span class="flag">--json</span> \\
<span class="ln">4</span>   | jq <span class="str">'[.[] | select(.active)]'</span> \\
<span class="ln">5</span>   | mcpd call filesystem/write_file \\
<span class="ln">6</span>     <span class="str">'{"path":"/tmp/active.json"}'</span> <span class="flag">-</span>`;

const codeNodeApi = `<span class="ln"> 1</span> <span class="kw">import</span> { createClient } <span class="kw">from</span> <span class="str">'mcpd'</span>;
<span class="ln"> 2</span>
<span class="ln"> 3</span> <span class="kw">const</span> client = <span class="kw">await</span> createClient();
<span class="ln"> 4</span>
<span class="ln"> 5</span> <span class="comment">// query churned customers from PostHog</span>
<span class="ln"> 6</span> <span class="kw">const</span> churn = <span class="kw">await</span> client.call(<span class="str">'posthog/query-run'</span>, {
<span class="ln"> 7</span>   query: { kind: <span class="str">'HogQLQuery'</span>, query: <span class="str">'SELECT email FROM persons'</span> }
<span class="ln"> 8</span> });
<span class="ln"> 9</span>
<span class="ln">10</span> <span class="comment">// pull support history in parallel</span>
<span class="ln">11</span> <span class="kw">const</span> history = <span class="kw">await</span> Promise.all(
<span class="ln">12</span>   customers.map(c =&gt;
<span class="ln">13</span>     client.call(<span class="str">'intercom/search-conversations'</span>, {
<span class="ln">14</span>       query: c.email, limit: 5
<span class="ln">15</span>     })
<span class="ln">16</span>   )
<span class="ln">17</span> );
<span class="ln">18</span>
<span class="ln">19</span> <span class="comment">// output the results</span>
<span class="ln">20</span> console.log(history);`;

const codeBefore = `<span class="output">⛁ ⛁ ⛁ ⛁ ⛁ ⛁ </span><span class="kw">⛁ </span><span class="flag">⛁ </span><span class="str">⛁ ⛁</span>
<span class="str">⛁ ⛁ ⛁ ⛁ ⛁ ⛁ ⛁ ⛁ ⛁ ⛁</span>`;

const codeAfter = `<span class="kw">⛁ </span><span class="flag">⛁ </span><span class="str">⛁ ⛁ ⛁ ⛁ ⛁ ⛁ ⛁ ⛁</span>
<span class="str">⛁ ⛁ ⛁ ⛁ </span><span class="comment">⛶ ⛶ ⛶ ⛶ ⛶ ⛶</span>`;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href="https://mcpd.dev" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://mcpd.dev" />
  </head>
  <body class="font-mono bg-page text-fg text-sm leading-[1.6] antialiased overflow-x-hidden">
    <!-- Navigation -->
    <div class="max-w-[960px] mx-auto px-6">
      <nav class="flex items-center justify-between py-4 border-b border-edge">
        <div
          class="font-bold text-[15px] -tracking-wide text-fg flex items-center gap-2"
        >
          <span class="text-brand">$</span> mcpd
        </div>
        <div class="flex items-center gap-4 md:gap-6 text-[13px]">
          <a
            href="/getting-started/installation/"
            class="text-fg-muted hover:text-fg transition-colors !no-underline"
            >Docs</a
          >
          <a
            href="https://github.com/skoob13/mcpd"
            class="text-fg-muted hover:text-fg transition-colors !no-underline"
            >GitHub</a
          >
          <a
            href="https://www.npmjs.com/package/mcpd"
            class="text-fg-muted hover:text-fg transition-colors !no-underline"
            >npm</a
          >
        </div>
      </nav>
    </div>

    <!-- Hero -->
    <div class="max-w-[960px] mx-auto px-6">
      <section class="py-16 md:py-28 section-divided overflow-hidden">
        <div class="text-center pt-4 md:pt-8 relative hero-glow">
          <pre
            class="ascii-logo text-fg text-[11px] leading-tight tracking-wider whitespace-pre mb-10 md:mb-12 opacity-50">{asciiLogo}</pre>

          <h1
            class="text-xl md:text-2xl font-semibold text-fg max-w-[600px] mx-auto mb-5 leading-snug"
          >
            Your agent wastes your time &mdash; and it's the tools' fault.
          </h1>
          <p
            class="text-[13px] text-fg-muted max-w-[540px] mx-auto mb-10 leading-relaxed"
          >
            Every MCP server you add dumps schemas into context, and the model
            spends tokens figuring out tools instead of doing your task. mcpd
            moves tools to a background daemon and discovers them lazily &mdash;
            via shell or Node.js API.
          </p>

          <div
            class="shimmer-border inline-flex items-center gap-3 bg-raised border border-edge rounded-lg px-5 py-3 text-sm mb-8 cursor-pointer hover:border-edge-light hover:bg-hover transition relative overflow-hidden"
            id="install-box"
          >
            <span class="text-green select-none">$</span>
            <span class="text-fg">npx mcpd init</span><span
              class="cursor-blink text-brand/80 ml-px">&#9611;</span
            >
            <span
              class="text-fg-faint text-[11px] ml-3 transition-colors"
              id="copy-hint">click to copy</span
            >
          </div>

          <div
            class="flex flex-col md:flex-row justify-center items-center gap-4 mt-8"
          >
            <a href="/getting-started/installation/" class="btn btn-primary"
              >Get Started</a
            >
            <a href="https://github.com/skoob13/mcpd" class="btn"
              >&#9733; Star on GitHub</a
            >
          </div>
        </div>
      </section>
    </div>

    <!-- The Problem -->
    <div class="max-w-[960px] mx-auto px-6">
      <section class="py-8 md:py-16 section-divided">
        <div class="text-center mb-6 md:mb-8">
          <h2
            class="text-[13px] font-normal tracking-[0.2em] uppercase text-fg-faint"
          >
            Your model is smart. Your context is not.
          </h2>
        </div>

        <p
          class="text-[13px] text-fg-muted leading-relaxed text-center max-w-[640px] mx-auto mb-8"
        >
          Every MCP server dumps its full schema into the prompt. The context
          fills up with tool definitions, and your agent stops following the
          instructions you actually wrote.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8 stats-stagger">
          <div
            class="bg-surface border border-edge rounded-lg p-6 text-center hover:border-edge-light transition animate-in"
          >
            <div class="text-[28px] font-bold text-brand mb-1 stat-glow">
              98.7%
            </div>
            <div class="text-[11px] text-fg-faint uppercase tracking-wide mb-2">
              token overhead
            </div>
            <p class="text-xs text-fg-muted">
              Anthropic found that intermediate tool results waste almost all
              tokens flowing through the model.
            </p>
          </div>
          <div
            class="bg-surface border border-edge rounded-lg p-6 text-center hover:border-edge-light transition animate-in"
          >
            <div class="text-[28px] font-bold text-brand mb-1 stat-glow">
              20-30%
            </div>
            <div class="text-[11px] text-fg-faint uppercase tracking-wide mb-2">
              context consumed
            </div>
            <p class="text-xs text-fg-muted">
              A standard MCP server setup fills a quarter of the context window
              before the agent even starts.
            </p>
          </div>
          <div
            class="bg-surface border border-edge rounded-lg p-6 text-center hover:border-edge-light transition animate-in"
          >
            <div class="text-[28px] font-bold text-brand mb-1 stat-glow">
              2-3
            </div>
            <div class="text-[11px] text-fg-faint uppercase tracking-wide mb-2">
              server limit
            </div>
            <p class="text-xs text-fg-muted">
              Tool selection accuracy collapses after just a handful of
              connected MCP servers.
            </p>
          </div>
        </div>

        <p class="text-sm text-fg font-medium text-center">
          The model is smart enough. It's the context that's broken &mdash;
          every token spent on schemas is a token not spent following your
          instructions.
        </p>
      </section>
    </div>

    <!-- Context Engineering (JTBD 2: trajectories) -->
    <div class="max-w-[960px] mx-auto px-6">
      <section class="py-8 md:py-16 section-divided">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
          <div>
            <h2 class="text-xl font-semibold mb-3 text-fg">
              Your agent follows instructions again
            </h2>
            <p class="text-[13px] text-fg-muted leading-relaxed">
              Skills, prompts, and default tools are deterministic &mdash;
              models always execute them. MCP tools compete for attention, and
              the more you add, the less your designed trajectories get
              followed.
            </p>
            <p class="text-[13px] text-fg-muted leading-relaxed mt-3">
              Offloading tools to mcpd is context engineering at the
              infrastructure level. Skills load first, the right MCP tools get
              called from there &mdash; exactly the trajectory you designed.
            </p>
          </div>

          <div class="flex flex-col gap-4">
            <!-- FAIL trajectory -->
            <div
              class="cc-terminal rounded-lg overflow-hidden border border-edge"
            >
              <div
                class="cc-header flex items-center gap-2 px-3 py-2 border-b border-edge"
              >
                <span
                  class="text-[11px] font-bold uppercase tracking-wide text-red"
                  >&#x2717; without mcpd</span
                >
              </div>
              <div class="flex flex-col gap-0 text-xs font-mono p-3">
                <div class="cc-user py-1.5">
                  <span class="text-brand font-bold">&gt;</span>
                  <span class="text-fg ml-2"
                    >Customer says the query doesn't work. Fix it.</span
                  >
                </div>
                <div class="cc-agent py-1.5 pl-4 border-l-2 border-edge ml-1">
                  <span class="text-fg-muted"
                    >I'll look through the available tools...</span
                  >
                </div>
                <div class="cc-tool py-1.5 pl-4 border-l-2 border-edge ml-1">
                  <span class="text-fg-faint">&#9881; </span>
                  <span class="text-fg-faint">postgres/execute_query</span>
                  <span class="text-red ml-2 text-[10px]">wrong tool</span>
                </div>
                <div class="cc-tool py-1.5 pl-4 border-l-2 border-edge ml-1">
                  <span class="text-fg-faint">&#9881; </span>
                  <span class="text-fg-faint">filesystem/read_file</span>
                  <span class="text-red ml-2 text-[10px]">wrong tool</span>
                </div>
                <div class="cc-tool py-1.5 pl-4 border-l-2 border-red/30 ml-1">
                  <span class="text-fg-faint italic">...38 more tool calls</span>
                  <span class="text-red ml-2 text-[10px]">no result</span>
                </div>
                <div class="cc-agent py-1.5 pl-4 border-l-2 border-red/30 ml-1">
                  <span class="text-red"
                    >skill "customer-analysis" never loaded</span
                  >
                </div>
              </div>
            </div>

            <!-- PASS trajectory -->
            <div
              class="cc-terminal rounded-lg overflow-hidden border border-edge trajectory-pass"
            >
              <div
                class="cc-header flex items-center gap-2 px-3 py-2 border-b border-edge"
              >
                <span
                  class="text-[11px] font-bold uppercase tracking-wide text-green"
                  >&#x2713; with mcpd</span
                >
              </div>
              <div class="flex flex-col gap-0 text-xs font-mono p-3">
                <div class="cc-user py-1.5">
                  <span class="text-brand font-bold">&gt;</span>
                  <span class="text-fg ml-2"
                    >Customer says the query doesn't work. Fix it.</span
                  >
                </div>
                <div class="cc-agent py-1.5 pl-4 border-l-2 border-edge ml-1">
                  <span class="text-fg"
                    >Loading skill "customer-analysis"...</span
                  >
                </div>
                <div
                  class="cc-tool py-1.5 pl-4 border-l-2 border-brand/30 ml-1"
                >
                  <span class="text-brand">$ </span>
                  <span class="text-fg">mcpd grep "query"</span>
                  <span class="text-fg-faint ml-2"
                    >&rarr; postgres/query_log</span
                  >
                </div>
                <div
                  class="cc-tool py-1.5 pl-4 border-l-2 border-brand/30 ml-1"
                >
                  <span class="text-brand">$ </span>
                  <span class="text-fg">mcpd call postgres/query_log</span>
                  <span class="text-green ml-2 text-[10px]">&#x2713;</span>
                </div>
                <div
                  class="cc-agent py-1.5 pl-4 border-l-2 border-green/30 ml-1"
                >
                  <span class="text-green"
                    >Fixed. The WHERE clause had a typo.</span
                  >
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>

    <!-- Features Grid -->
    <div class="max-w-[960px] mx-auto px-6">
      <section class="py-8 md:py-16 section-divided">
        <div class="text-center mb-6 md:mb-8">
          <h2
            class="text-[13px] font-normal tracking-[0.2em] uppercase text-fg-faint"
          >
            How mcpd fixes this
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 features-stagger">
          <div
            class="feature-card bg-surface border border-edge rounded-lg p-6 hover:border-edge-light transition-all animate-in"
          >
            <div class="text-sm mb-3 text-brand leading-none">-98%</div>
            <h3 class="text-[13px] font-semibold mb-2 text-fg">
              Lazy discovery
            </h3>
            <p class="text-xs text-fg-muted leading-relaxed">
              Tools live in the daemon, not the prompt. Agents find what they
              need with <code
                class="text-brand bg-raised px-1 py-px rounded text-[11px]"
                >mcpd grep</code
              > &mdash; no schema preloading, no token waste.
            </p>
          </div>
          <div
            class="feature-card bg-surface border border-edge rounded-lg p-6 hover:border-edge-light transition-all animate-in"
          >
            <div class="text-lg mb-3 text-brand leading-none">&#x25ce;</div>
            <h3 class="text-[13px] font-semibold mb-2 text-fg">
              Trajectories that hold
            </h3>
            <p class="text-xs text-fg-muted leading-relaxed">
              Clean context means skills and prompts get followed. Your agent
              loads instructions first, then calls the right tool.
            </p>
          </div>
          <div
            class="feature-card bg-surface border border-edge rounded-lg p-6 hover:border-edge-light transition-all animate-in"
          >
            <div class="text-lg mb-3 text-brand leading-none">&#123;&#125;</div>
            <h3 class="text-[13px] font-semibold mb-2 text-fg">
              One daemon, every agent
            </h3>
            <p class="text-xs text-fg-muted leading-relaxed">
              Configure once, use everywhere. mcpd reads your existing agent
              configs &mdash; zero per-agent setup.
            </p>
          </div>
          <div
            class="feature-card bg-surface border border-edge rounded-lg p-6 hover:border-edge-light transition-all animate-in"
          >
            <div class="text-lg mb-3 text-brand leading-none">|&gt;</div>
            <h3 class="text-[13px] font-semibold mb-2 text-fg">Script it</h3>
            <p class="text-xs text-fg-muted leading-relaxed">
              Chain MCP calls through bash pipes or Node.js. Automate routines
              without burning tokens on repeated tool calls.
            </p>
          </div>
        </div>
      </section>
    </div>

    <!-- Code Example: Discovery -->
    <div class="max-w-[960px] mx-auto px-6">
      <section class="py-8 md:py-16 section-divided">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
          <div>
            <h2 class="text-xl font-semibold mb-3 text-fg">
              Discover, don't preload
            </h2>
            <p class="text-[13px] text-fg-muted leading-relaxed">
              Instead of loading every schema into the prompt, agents search for
              the tool they need, inspect it, and call it. The model's context
              stays clean &mdash; only the final result goes in.
            </p>
          </div>

          <div
            class="code-block bg-surface border border-edge rounded-lg overflow-hidden"
          >
            <div
              class="code-header flex items-center gap-2 px-4 py-3 border-b border-edge"
            >
              <div class="w-2.5 h-2.5 rounded-full bg-[#ff5f57]"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-[#febc2e]"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-[#28c840]"></div>
              <span class="text-[11px] text-fg-faint ml-2">terminal</span>
            </div>
            <pre
              class="p-4 text-xs leading-relaxed overflow-x-auto"
              set:html={codeDiscovery}
            />
          </div>
        </div>
      </section>
    </div>

    <!-- Context window: before / after -->
    <div class="max-w-[960px] mx-auto px-6">
      <section class="py-8 md:py-16 section-divided">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
          <div>
            <h2 class="text-xl font-semibold mb-3 text-fg">
              Reclaim 30% of your context window
            </h2>
            <p class="text-[13px] text-fg-muted leading-relaxed">
              A typical MCP setup burns a third of the context on tool schemas
              the agent may never use. mcpd moves them out entirely &mdash;
              freeing space for the skills, prompts, and conversation that
              actually drive results.
            </p>
          </div>

          <div class="flex flex-col gap-4">
            <div class="bg-surface border border-edge rounded-lg p-4">
              <div
                class="text-[11px] font-bold uppercase tracking-wide font-mono mb-3 text-red"
              >
                before mcpd:
              </div>
              <div
                class="flex flex-col sm:flex-row gap-4 sm:gap-6 items-start sm:items-center"
              >
                <pre
                  class="context-grid font-mono text-[13px] leading-[1.6] text-fg p-0 m-0"
                  set:html={codeBefore}
                />
                <div
                  class="context-legend grid grid-cols-2 gap-x-4 gap-y-1 text-[11px] font-mono text-fg-muted"
                >
                  <div><span class="output">⛁</span> mcp 30%</div>
                  <div><span class="kw">⛁</span> skills 6%</div>
                  <div><span class="flag">⛁</span> prompts 6%</div>
                  <div><span class="str">⛁</span> task 58%</div>
                </div>
              </div>
            </div>
            <div
              class="bg-surface border border-edge rounded-lg p-4 trajectory-pass"
            >
              <div
                class="text-[11px] font-bold uppercase tracking-wide font-mono mb-3 text-green"
              >
                after mcpd:
              </div>
              <div
                class="flex flex-col sm:flex-row gap-4 sm:gap-6 items-start sm:items-center"
              >
                <pre
                  class="context-grid font-mono text-[13px] leading-[1.6] text-fg p-0 m-0"
                  set:html={codeAfter}
                />
                <div
                  class="context-legend grid grid-cols-2 gap-x-4 gap-y-1 text-[11px] font-mono text-fg-muted"
                >
                  <div><span class="kw">⛁</span> skills 6%</div>
                  <div><span class="flag">⛁</span> prompts 6%</div>
                  <div><span class="str">⛁</span> task 58%</div>
                  <div><span class="comment">⛶</span> free 30%</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>

    <!-- Code Example: Scripting -->
    <div class="max-w-[960px] mx-auto px-6">
      <section class="py-8 md:py-16 section-divided">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
          <div>
            <h2 class="text-xl font-semibold mb-3 text-fg">
              Automate what you keep repeating
            </h2>
            <p class="text-[13px] text-fg-muted leading-relaxed">
              Stop burning tokens on the same routine tasks. Chain MCP calls
              through bash pipes or write Node.js scripts &mdash; intermediate
              data never re-enters the model.
            </p>
            <p class="text-[13px] text-fg-muted leading-relaxed mt-3">
              Same insight behind Anthropic's code execution and Cloudflare's
              Code Mode &mdash; as a CLI and npm package.
            </p>
          </div>

          <div
            class="code-block bg-surface border border-edge rounded-lg overflow-hidden"
          >
            <div
              class="code-header flex items-center gap-2 px-4 py-3 border-b border-edge"
            >
              <div class="w-2.5 h-2.5 rounded-full bg-[#ff5f57]"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-[#febc2e]"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-[#28c840]"></div>
              <span class="text-[11px] text-fg-faint ml-2"
                >bash &mdash; pipe through jq</span
              >
            </div>
            <pre
              class="p-4 text-xs leading-relaxed overflow-x-auto"
              set:html={codeChaining}
            />
          </div>
        </div>
      </section>
    </div>

    <!-- Node.js API -->
    <div class="max-w-[960px] mx-auto px-6">
      <section class="py-8 md:py-16 section-divided">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
          <div>
            <h2 class="text-xl font-semibold mb-3 text-fg">
              Node.js and Bash APIs
            </h2>
            <p class="text-[13px] text-fg-muted leading-relaxed">
              mcpd is also an npm package. Agents write Node.js scripts with
              typed results, <code
                class="text-brand bg-raised px-1 py-px rounded text-[11px]"
                >Promise.all</code
