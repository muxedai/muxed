{
  "env": {
    "ENABLE_EXPERIMENTAL_MCP_CLI": "true"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/setup-cloud.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(pnpm install:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm format:*)",
      "Bash(pnpm format\\:check:*)",
      "Bash(pnpm type-check:*)",
      "Bash(pnpm dev:*)",
      "Bash(node src/cli.ts:*)",
      "Bash(node bin/cli.mjs:*)"
    ]
  }
}
