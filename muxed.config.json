{
  "mcpServers": {
    "posthog-prod": {
      "type": "http",
      "url": "https://mcp.posthog.com/mcp",
      "headers": {
        "x-posthog-mcp-version": "2"
      }
    },
    "posthog": {
      "command": "-t",
      "args": [
        "http",
        "https://mcp.posthog.com/mcp",
        "-H",
        "x-posthog-project-id: 2"
      ]
    }
  }
}
